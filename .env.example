# ---- LLM Provider (LiteLLM) — used for RAG queries ----
# Set the model string for your provider. Examples:
#   LITELLM_MODEL=gpt-4o                          # OpenAI
#   LITELLM_MODEL=azure/my-gpt4o-deployment        # Azure OpenAI
#   LITELLM_MODEL=anthropic/claude-sonnet-4-20250514     # Anthropic
#   LITELLM_MODEL=ollama/llama3                    # Ollama (local)
# See https://docs.litellm.ai/docs/providers for all supported providers.
LITELLM_MODEL=gpt-4o

# ---- VLM Provider (LiteLLM) — used for image/slide descriptions during ingestion ----
# Must be a vision-capable model. Examples:
#   LITELLM_VLM_MODEL=gpt-4o                      # OpenAI
#   LITELLM_VLM_MODEL=azure/my-gpt4o-deployment    # Azure OpenAI
#   LITELLM_VLM_MODEL=anthropic/claude-sonnet-4-20250514 # Anthropic
#   LITELLM_VLM_MODEL=ollama/llava                 # Ollama (local)
LITELLM_VLM_MODEL=gpt-4o

# Provider-specific keys (set whichever applies):
# OPENAI_API_KEY=sk-...
# AZURE_API_KEY=...
# AZURE_API_BASE=https://your-resource.openai.azure.com/
# AZURE_API_VERSION=2024-12-01-preview
# ANTHROPIC_API_KEY=sk-ant-...
